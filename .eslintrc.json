{
	"root": true,
	"extends": [
		"wikimedia/client",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"parserOptions": {
		"sourceType": "commonjs",
		"ecmaVersion": 2017
	},
	"globals": {
		"collabpad": "readonly",
		"collabpads": "readonly",
		"jQuery": "readonly",
		"mediaWiki": "readonly",
		"mws": "readonly",
		"OOJSPlus": "readonly",
		"ve": "readonly",
		"bs": "readonly"
	},
	"rules": {
		"camelcase": "off",
		"no-jquery/no-done-fail": "warn",
		"es-x/no-array-prototype-includes": "off",
		"es-x/no-async-functions": "off",
		"max-len": "off"
	}
}
